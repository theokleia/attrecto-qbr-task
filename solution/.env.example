# QBR Automation System — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Anthropic (required for live LLM calls) ────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── OpenAI (optional — used for noise filter micro-classifier) ────────────
# If not set, the Anthropic model is used for all stages.
OPENAI_API_KEY=your-openai-api-key-here

# ── Model selection (optional — defaults shown) ───────────────────────────
# Primary model for Stages B, C, D (validation + report generation)
PRIMARY_MODEL=claude-sonnet-4-6

# Micro-classifier model for noise filter Stage 1b (fast, low-cost)
# Options: gpt-5-nano, gpt-5-mini, claude-haiku-4-5-20251001
MICRO_CLASSIFIER_MODEL=gpt-5-nano

# ── Jira integration (optional — for Concept B Jira-first architecture) ──
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_USER_EMAIL=your-email@company.com

# ── Analysis settings (optional) ─────────────────────────────────────────
# Business days before a question is considered stalled (default: 5)
STALLED_THRESHOLD_DAYS=5

# Confidence threshold below which flags go to Needs PM Review (default: 0.70)
CONFIDENCE_THRESHOLD=0.70

# Reference date for "days open" calculation (default: last day of current quarter)
# Set this to the last day of the quarter you are reporting on: YYYY-MM-DD
# For Q2 2025 (the sample data): 2025-07-31
# ANALYSIS_REFERENCE_DATE=2025-07-31
