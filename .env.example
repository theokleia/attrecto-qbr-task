# =============================================================================
# JIRA CONFIGURATION
# Leave all JIRA_ fields blank to use mock data instead of real Jira
# =============================================================================

# Your Jira instance URL (e.g. https://yourcompany.atlassian.net)
JIRA_BASE_URL=

# Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_KEY=

# Email address associated with your Jira account
JIRA_EMAIL=

# Comma-separated list of Jira project keys to include in the report
# Example: PROJ1,PROJ2,PHOENIX
JIRA_PROJECT_IDS=

# Comma-separated list of issue types to analyze
# Example: Bug,Story,Task,Epic,Incident
JIRA_ISSUE_TYPES=Bug,Story,Task,Epic

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# OpenAI API key (used for discovery/ideation layer - gpt-5-mini)
OPENAI_API_KEY=

# Anthropic API key (used for core analytical engine - claude-sonnet-4-6 / claude-opus-4-6)
ANTHROPIC_API_KEY=

# =============================================================================
# REPORT CONFIGURATION
# =============================================================================

# Quarter being reported on (e.g. Q2-2025, Q1-2026)
REPORT_QUARTER=Q2-2025

# Directory where the HTML report will be written (relative to solution/)
REPORT_OUTPUT_DIR=output

# Path to email data directory (relative to project root)
EMAIL_DATA_DIR=input/AI_Developer_files
